{
  "name": "@itharbors/harbors",
  "version": "0.1.0",
  "workspaces": ["app"],
  "bin": "./workflow/dist/cli.js",
  "description": "",
  "main": "./app/dist/index.js",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepublishOnly": "npm run clean && npm install && npm run build && npm run test",
    "preinstall": "cd ../workflow && npm install",
