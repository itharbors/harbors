    "ci": "npm install && npm run build && npm run test"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "electron": "^35.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.2",
    "esbuild": "^0.25.3",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  }
}