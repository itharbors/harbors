{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@type/*": ["../app/type/*"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules"]
}
