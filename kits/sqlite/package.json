{
  "name": "@itharbors/kit-sqlite",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run --config vitest.config.ts"
  },
  "ce-editor": {
    "kit": {
      "menuRoot": {
        "id": "sqlite",
        "label": "SQLite"
      },
      "layouts": {
        "default": "layout.json"
      },
      "windowEntries": {
        "main": "main.html",
        "secondary": "secondary.html"
      },
      "plugin": [
