{
  "windows": [
    {
      "id": "sqlite-main",
      "kind": "main",
      "type": "panel-area",
      "layout": {
        "type": "vsplit",
        "sizes": [78, 1],
        "children": [
          {
            "type": "leaf",
            "panel": "@itharbors/sqlite-explorer.connection",
            "panelType": "simple"
          },
          {
            "type": "hsplit",
            "sizes": [250, 1],
            "children": [
              {
                "type": "leaf",
                "panel": "@itharbors/sqlite-explorer.explorer",
                "panelType": "simple"
              },
              {
                "type": "tab",
                "activeIndex": 0,
                "children": [
                  {
                    "type": "leaf",
                    "panel": "@itharbors/sqlite-data.data"
                  },
                  {
                    "type": "leaf",
                    "panel": "@itharbors/sqlite-schema.schema"
                  },
                  {
                    "type": "leaf",
                    "panel": "@itharbors/sqlite-relationships.relationships"
                  },
                  {
                    "type": "leaf",
                    "panel": "@itharbors/sqlite-sql.sql"
                  }
                ]
              }
            ]
          }
        ]
      }
    }
  ],
  "activePanel": "@itharbors/sqlite-data.data"
}
