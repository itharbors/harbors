{
  "name": "@itharbors/sqlite-explorer",
  "version": "0.0.1",
  "type": "module",
  "main": "./main/dist/index.js",
  "dependencies": {
    "@itharbors/sqlite-contracts": "0.0.1"
  },
  "ce-editor": {
    "contribute": {
      "panel": {
        "connection": {
          "entry": "./panel.connection/dist/index.html",
          "title": "SQLite 数据库连接",
          "minWidth": 320,
          "minHeight": 64,
          "multiInstance": false
        },
        "explorer": {
          "entry": "./panel.explorer/dist/index.html",
          "title": "SQLite 数据库对象",
          "minWidth": 200,
          "minHeight": 320,
          "multiInstance": false
        }
      },
      "message": {
        "request": {
          "getSelection": ["getSelection"],
          "getObjectsSnapshot": ["getObjectsSnapshot"],
          "refreshObjects": ["refreshObjects"],
          "selectObject": ["selectObject"]
        },
        "broadcast": {
          "@itharbors/sqlite.connection.changed": ["onConnectionChanged", "panel.onConnectionChanged"],
          "@itharbors/sqlite.schema.changed": ["onSchemaChanged"],
          "@itharbors/sqlite.objects.changed": ["panel.onObjectsChanged"]
        }
      }
    }
  }
}
