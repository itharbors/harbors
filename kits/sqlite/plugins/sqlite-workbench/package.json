{
  "name": "@itharbors/sqlite-workbench",
  "version": "0.0.1",
  "type": "module",
  "main": "./main/dist/index.js",
  "dependencies": {
    "better-sqlite3": "^11.0.0"
  },
  "ce-editor": {
    "contribute": {
      "panel": {
        "workbench": {
          "entry": "./panel.workbench/dist/index.html",
          "title": "SQLite 工作台",
          "minWidth": 560,
          "minHeight": 360,
          "multiInstance": false
        }
      },
      "message": {
        "request": {
          "getConnectionState": ["getConnectionState"],
          "openDatabase": ["openDatabase"],
          "closeDatabase": ["closeDatabase"],
          "getSchema": ["getSchema"],
          "getObjectSchema": ["getObjectSchema"],
          "getRows": ["getRows"],
          "insertRow": ["insertRow"],
          "updateRow": ["updateRow"],
          "deleteRow": ["deleteRow"],
          "executeSql": ["executeSql"]
        }
      }
    }
  }
}
