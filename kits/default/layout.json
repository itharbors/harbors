{
  "windows": [
    {
      "id": "default-main",
      "type": "panel-area",
      "layout": {
        "type": "vsplit",
        "sizes": [32, 1, 220, 28],
        "children": [
          {
            "type": "leaf",
            "panel": "@itharbors/title-bar.title",
            "panelType": "simple"
          },
          {
            "type": "hsplit",
            "sizes": [340, 1],
            "children": [
              {
                "type": "leaf",
                "panel": "@itharbors/plugin-list.list"
              },
              {
                "type": "vsplit",
                "sizes": [1, 220],
                "children": [
                  {
                    "type": "leaf",
                    "panel": "@itharbors/plugin-detail.detail"
                  },
                  {
                    "type": "leaf",
                    "panel": "@itharbors/message-debug.debug"
                  }
                ]
              }
            ]
          },
          {
            "type": "leaf",
            "panel": "@itharbors/log.log"
          },
          {
            "type": "leaf",
            "panel": "@itharbors/status-bar.status",
            "panelType": "simple"
          }
        ]
      }
    }
  ],
  "activePanel": "@itharbors/log.log"
}
