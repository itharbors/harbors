{
  "name": "@ce/plugin-detail",
  "version": "0.0.1",
  "type": "module",
  "main": "./main/dist/index.js",
  "ce-editor": {
    "contribute": {
      "panel": {
        "detail": {
          "entry": "./panel.detail/dist/index.html"
        }
      },
      "message": {
        "broadcast": {
          "plugin.selected": [
