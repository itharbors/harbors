          ]
        }
      },
      "menu": [
        {
          "type": "menu",
          "id": "view/panels/ce-plugin-detail-detail",
          "message": "openDetailPanel",
          "order": 1020,
          "label": "Plugin Detail"
        }
      ]
    }
  }
}
