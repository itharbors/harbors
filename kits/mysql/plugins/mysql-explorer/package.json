{
  "name": "@itharbors/mysql-explorer",
  "version": "0.0.1",
  "type": "module",
  "main": "./main/dist/index.js",
  "dependencies": {
    "@itharbors/mysql-contracts": "0.0.1"
  },
  "ce-editor": {
    "contribute": {
      "panel": {
        "explorer": {
          "entry": "./panel.explorer/dist/index.html",
          "title": "MySQL 资源管理器",
          "minWidth": 240,
          "minHeight": 320,
          "multiInstance": false
        }
      },
      "message": {
        "request": {
          "getSelection": ["getSelection"],
          "selectObject": ["selectObject"]
        },
        "broadcast": {
          "@itharbors/mysql.connection.changed": ["onConnectionChanged", "panel.onConnectionChanged"],
          "@itharbors/mysql.schema.changed": ["onSchemaChanged", "panel.onSchemaChanged"]
        }
      }
    }
  }
}
